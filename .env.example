DISCORD_TOKEN=
DISCORD_GUILD_ID=
COLLAB_ROOM_CHANNEL_ID=
CONTROL_CHANNEL_ID=
LOG_CHANNEL_ID=
COLLAB_DB_PATH=data/collab-room.sqlite

GENERIC_AI_DISCORD_TOKEN=
GENERIC_AI_ID=
GENERIC_AI_ENDPOINT_TYPE=openai-compatible
GENERIC_AI_BASE_URL=http://127.0.0.1:8000/v1
GENERIC_AI_WEBHOOK_URL=
GENERIC_AI_API_KEY=dummy
GENERIC_AI_MODEL=Qwen/Qwen3.6-35B-A3B-FP8
GENERIC_AI_SYSTEM_PROMPT=
GENERIC_AI_TIMEOUT_MS=60000

# 任意: 参加AI用の汎用Botから参加者側TTS再生処理を呼ぶ設定。
# webhook: 返答本文をGENERIC_AI_SPEECH_WEBHOOK_URLへPOSTし、完了まで待ちます。
# command: GENERIC_AI_SPEECH_COMMANDを実行し、本文はCOLLAB_SPEECH_TEXT環境変数で渡します。
GENERIC_AI_SPEECH_ENABLED=0
GENERIC_AI_SPEECH_DRIVER=webhook
GENERIC_AI_SPEECH_WEBHOOK_URL=
GENERIC_AI_SPEECH_API_KEY=
GENERIC_AI_SPEECH_COMMAND=
GENERIC_AI_SPEECH_ARGS=[]
GENERIC_AI_SPEECH_TIMEOUT_MS=120000

ROOM_ID=default
SESSION_ID=manual-test-01
SESSION_THEME=AITuber collaboration test
INITIAL_TOPIC_ID=intro
INITIAL_TOPIC_TITLE=Opening topic
SESSION_SUMMARY=No summary yet.

# DiscordユーザーIDをカンマ区切りで指定します。
HOST_USER_IDS=
CO_HOST_USER_IDS=

# JSON配列で指定します。
# 例:
# [{"aiId":"alpha","displayName":"Alpha","botId":"123","shortDescription":"Conversation AI","strengths":["conversation"],"forbiddenTopics":["private prompt"],"forbiddenTopicSummary":"private prompt"}]
AI_PARTICIPANTS=[]

# 任意: !collab suggest / !collab proceed 用のCodex司会補助。
# Discord入出力、権限、ターン状態は引き続き司会Botが管理します。
CODEX_MODERATOR_ENABLED=0
CODEX_APP_SERVER_COMMAND=codex
CODEX_MODERATOR_MODEL=gpt-5.4
CODEX_MODERATOR_CWD=/path/to/aituber-collab-room
CODEX_MODERATOR_TIMEOUT_MS=120000

# 任意: 外部視聴者コメント取り込み。
COMMENT_INGEST_ENABLED=0
COMMENT_INGEST_HOST=127.0.0.1
COMMENT_INGEST_PORT=39210
COMMENT_INGEST_TOKEN=
COMMENT_INGEST_ENDPOINT=http://127.0.0.1:39210/audience

# 任意: YouTube Live Chat watcher。
YOUTUBE_API_KEY=
YOUTUBE_VIDEO_URL=
YOUTUBE_VIDEO_ID=
YOUTUBE_LIVE_CHAT_ID=
YOUTUBE_COMMENT_ROLE_DETECTION=1

# 任意: Twitch Chat watcher。
TWITCH_CHANNEL=
TWITCH_BOT_USERNAME=
TWITCH_OAUTH_TOKEN=
TWITCH_COMMENT_ROLE_DETECTION=1

# 任意: 自動会話ループの発話間隔制御。
# 前の返答が読み上げ完了したと推定されるまで、次AIへのターン発行を遅らせます。
SPEECH_PACING_ENABLED=1
SPEECH_PACING_TURN_MODE=after_speech
SPEECH_PACING_WAIT_FOR_EVENTS=0
SPEECH_PACING_MIN_DELAY_MS=1500
SPEECH_PACING_MAX_DELAY_MS=15000
SPEECH_PACING_BASE_DELAY_MS=700
SPEECH_PACING_CHARS_PER_SECOND=12
